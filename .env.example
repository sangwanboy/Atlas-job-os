# Core runtime
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=AI Job Intelligence Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_job_dashboard?schema=public

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret

# AI providers (set at least one)
# Keys are written to .env.local for persistence across restarts. Never commit .env.local to git.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4.1-mini

# Browser automation layer (Playwright)
BROWSER_HEADLESS=true
BROWSER_ACTION_TIMEOUT_MS=10000
BROWSER_ACTION_RETRY_COUNT=2
BROWSER_MAX_ACTIONS_PER_SESSION=60
BROWSER_ALLOWED_DOMAINS=
BROWSER_CONFIRMATION_ACTIONS=browser_click,browser_type
BROWSER_SCREENSHOT_DIR=artifacts/browser

# Optional queue infra
REDIS_URL=redis://localhost:6379

# Observability
LOG_LEVEL=info
